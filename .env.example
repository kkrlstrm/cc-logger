# cc-logger configuration
# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# ============================================================
# DATABASE
# ============================================================
# Postgres connection string. Pick ONE of the two paths below.

# Path A — Docker Compose Postgres (default, easiest)
# Leave this URL as-is if you're using `docker compose up`. It points at
# the Postgres service in docker-compose.yml.
DATABASE_URL=postgresql://cclogger:cclogger@localhost:5432/cclogger

# Path B — Bring your own Postgres (Neon, Supabase, RDS, local install)
# Replace DATABASE_URL above with your own connection string. For Neon,
# use the DIRECT endpoint (the host WITHOUT `-pooler` in it) — the pooler
# is incompatible with long-lived prepared statements. Example:
#   DATABASE_URL=postgresql://user:password@ep-name.us-east-1.aws.neon.tech/dbname?sslmode=require

# ============================================================
# SERVICE
# ============================================================
# Port the FastAPI service listens on (127.0.0.1 only).
HOOK_PORT=8787

# Log level (debug|info|warning|error).
LOG_LEVEL=info

# ============================================================
# PRIVACY
# ============================================================
# Redact common secret patterns (API keys, bearer tokens, passwords in DSNs)
# from tool_input/tool_response BEFORE writing to the DB. Default: on.
# Set to 0 if you want raw capture (e.g., for personal use on a private DB).
REDACT_SECRETS=1
